{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/1688-supplier-discovery/interface/research-request.schema.json",
  "title": "1688 Supplier Discovery Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interface_version",
    "request_id",
    "product_direction"
  ],
  "properties": {
    "interface_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "product_direction": {
      "type": "string",
      "minLength": 1
    },
    "search_phrases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "price_band": {
          "type": "string"
        },
        "moq_preference": {
          "type": "string"
        },
        "preferred_supplier_regions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "target_materials": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "must_have_traits": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_avoid_traits": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operator_notes": {
      "type": "string"
    },
    "output_preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "report_format": {
          "type": "string",
          "enum": [
            "markdown"
          ]
        },
        "output_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
