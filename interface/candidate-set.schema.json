{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/1688-supplier-discovery/interface/candidate-set.schema.json",
  "title": "1688 Supplier Discovery Candidate Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interface_version",
    "request_id",
    "phase",
    "evidence_mode",
    "search_strategy",
    "candidates"
  ],
  "properties": {
    "interface_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "const": "search_harvest"
    },
    "evidence_mode": {
      "type": "string",
      "enum": [
        "direct_1688",
        "mirror_assisted",
        "none"
      ]
    },
    "search_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phrases_attempted",
        "phrase_limit",
        "product_page_open_limit_per_phrase"
      ],
      "properties": {
        "phrases_attempted": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "phrase_limit": {
          "type": "integer",
          "minimum": 1
        },
        "product_page_open_limit_per_phrase": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "search_page_links": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "rank",
          "search_phrase",
          "product_title",
          "evidence_page_link",
          "visible_clues",
          "selection_reason"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "search_phrase": {
            "type": "string",
            "minLength": 1
          },
          "supplier_name": {
            "type": "string",
            "minLength": 1
          },
          "product_title": {
            "type": "string",
            "minLength": 1
          },
          "evidence_page_link": {
            "type": "string",
            "minLength": 1
          },
          "source_1688_link": {
            "type": "string",
            "minLength": 1
          },
          "supplier_page_link": {
            "type": "string",
            "minLength": 1
          },
          "visible_clues": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "selection_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
