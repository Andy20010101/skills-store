{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/1688-supplier-discovery/interface/evidence-notes.schema.json",
  "title": "1688 Supplier Discovery Evidence Notes",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interface_version",
    "request_id",
    "phase",
    "evidence_mode",
    "reviewed_candidates"
  ],
  "properties": {
    "interface_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "const": "evidence_pass"
    },
    "evidence_mode": {
      "type": "string",
      "enum": [
        "direct_1688",
        "mirror_assisted",
        "none"
      ]
    },
    "reviewed_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "status",
          "evidence_pages",
          "page_visible_facts",
          "heuristic_judgments",
          "unknowns"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "kept",
              "rejected",
              "blocked"
            ]
          },
          "supplier_name": {
            "type": "string",
            "minLength": 1
          },
          "product_title": {
            "type": "string",
            "minLength": 1
          },
          "supplier_page_link": {
            "type": "string",
            "minLength": 1
          },
          "evidence_pages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "page_role",
                "evidence_page_link",
                "page_summary"
              ],
              "properties": {
                "page_role": {
                  "type": "string",
                  "enum": [
                    "search_result",
                    "product_detail",
                    "supplier_page"
                  ]
                },
                "evidence_page_link": {
                  "type": "string",
                  "minLength": 1
                },
                "source_1688_link": {
                  "type": "string",
                  "minLength": 1
                },
                "page_summary": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "page_visible_facts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "heuristic_judgments": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "unknowns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "representative_products": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "title",
                "evidence_link",
                "visible_price_moq",
                "notes"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "evidence_link": {
                  "type": "string",
                  "minLength": 1
                },
                "source_1688_link": {
                  "type": "string",
                  "minLength": 1
                },
                "visible_price_moq": {
                  "type": "string",
                  "minLength": 1
                },
                "notes": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "rejection_reason": {
            "type": "string",
            "minLength": 1
          },
          "blocker": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
